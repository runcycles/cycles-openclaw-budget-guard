{
  "name": "@runcycles/openclaw-budget-guard",
  "version": "0.8.4",
  "description": "Runtime budget, action, and audit authority for OpenClaw agents — enforce LLM cost limits, tool call caps, and audit trails before execution.",
  "keywords": [
    "ai-agent",
    "agent-budget",
    "agent-governance",
    "budget-control",
    "cost-control",
    "cost-enforcement",
    "spending-limit",
    "llm-cost",
    "runtime-authority",
    "action-control",
    "action-authority",
    "audit-trail",
    "audit",
    "compliance",
    "multi-tenant",
    "openclaw",
    "openclaw-plugin",
    "mcp",
    "claude",
    "anthropic",
    "openai",
    "cycles",
    "runcycles"
  ],
  "license": "Apache-2.0",
  "author": "runcycles",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runcycles/cycles-openclaw-budget-guard.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "runcycles": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
