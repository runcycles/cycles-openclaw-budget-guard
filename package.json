{
  "name": "@runcycles/openclaw-budget-guard",
  "version": "0.7.7",
  "description": "OpenClaw plugin for budget-aware model and tool execution using Cycles.",
  "license": "Apache-2.0",
  "author": "runcycles",
  "repository": {
    "type": "git",
    "url": "https://github.com/runcycles/cycles-openclaw-budget-guard.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "runcycles": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
