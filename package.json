{
  "name": "@runcycles/openclaw-budget-guard",
  "version": "0.1.0",
  "description": "OpenClaw plugin for budget-aware model and tool execution using Cycles.",
  "license": "Apache-2.0",
  "author": "runcycles",
  "repository": {
    "type": "git",
    "url": "https://github.com/runcycles/cycles-openclaw-budget-guard.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": {
      "plugin": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "runcycles": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
